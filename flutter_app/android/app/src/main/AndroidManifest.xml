<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Rede (backend Recorpo) -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Câmera para o scanner de refeição (Lote 9) e OCR de prescrição
         (Lote 10). image_picker também aciona a captura. -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false"/>

    <!-- Health Connect (Lote 11). Cada leitura é solicitada em tempo de
         execução ao usuário via UI do próprio Health Connect. -->
    <uses-permission android:name="android.permission.health.READ_HEART_RATE"/>
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED"/>

    <!-- Notificações locais (Lote 19). POST_NOTIFICATIONS é exigido no
         Android 13+ e pedido em runtime. SCHEDULE_EXACT_ALARM garante
         que o horário do lembrete (18h / 22h / dose) não seja adiado
         pelo Doze mode. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <uses-permission android:name="android.permission.USE_EXACT_ALARM"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <application
        android:label="Recorpo"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Deep link para o Health Connect declarar permissões de
                 leitura (exigido pelo package `health` v13). -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE"/>
            </intent-filter>
        </activity>
        <!-- Alias para Android 13+ (API 33) — Health Connect procura o
             rationale por essa activity-alias. -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE"/>
                <category android:name="android.intent.category.HEALTH_PERMISSIONS"/>
            </intent-filter>
        </activity-alias>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- Widget "Refeição" (Lote 17) — pílula na home do Android
             que abre a câmera direto. Registra o AppWidgetProvider e
             aponta para o XML de metadados. -->
        <receiver
            android:name=".RefeicaoWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/refeicao_widget_info" />
        </receiver>

        <!-- Widget "Água" (Lote 18) — barra com +250/+500 e valor
             central. Botões disparam BroadcastReceiver do package
             home_widget que roda callback Dart em background. -->
        <receiver
            android:name=".AguaWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/agua_widget_info" />
        </receiver>

        <!-- Background receiver do package home_widget — recebe os
             cliques dos botões +250/+500 e enfileira o callback Dart
             para rodar em isolate isolado. -->
        <receiver
            android:name="es.antonborri.home_widget.HomeWidgetBackgroundReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="es.antonborri.home_widget.action.BACKGROUND" />
            </intent-filter>
        </receiver>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Consulta o app Health Connect (Android 13-) — obrigatório
             pelo package `health` v13 para descobrir se o HC está
             instalado. -->
        <package android:name="com.google.android.apps.healthdata"/>
    </queries>
</manifest>
