<?xml version="1.0" encoding="utf-8"?>
<!--
    Metadados do widget "Refeição" do Recorpo (Lote 17).
    Tamanho 2x1 (mínimo 40dp altura, 110dp largura) — bom equilíbrio
    entre visibilidade e ocupação da home. Configurável (resizable=none)
    porque o layout é fixo em pílula.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="40dp"
    android:targetCellWidth="2"
    android:targetCellHeight="1"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/refeicao_widget"
    android:resizeMode="none"
    android:widgetCategory="home_screen"
    android:previewLayout="@layout/refeicao_widget"
    android:description="@string/refeicao_widget_desc" />
