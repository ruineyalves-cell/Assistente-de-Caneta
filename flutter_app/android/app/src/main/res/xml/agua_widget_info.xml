<?xml version="1.0" encoding="utf-8"?>
<!-- Metadados do widget de Água (Lote 18) — 3x1, um pouco maior que o
     de refeição para caber os 3 elementos (+250, valor, +500). -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="180dp"
    android:minHeight="60dp"
    android:targetCellWidth="3"
    android:targetCellHeight="1"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/agua_widget"
    android:resizeMode="horizontal"
    android:widgetCategory="home_screen"
    android:previewLayout="@layout/agua_widget"
    android:description="@string/agua_widget_desc" />
