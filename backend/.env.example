# Database (PostgreSQL Render)
DATABASE_URL=postgresql://appuser:PASSWORD@your-render-host.ohio-postgres.render.com/assistente_caneta?sslmode=require

# Server
NODE_ENV=production
PORT=3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-in-prod
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=30d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=*

# Monitoring (Optional)
SENTRY_DSN=

# Email (Optional)
SENDGRID_API_KEY=
