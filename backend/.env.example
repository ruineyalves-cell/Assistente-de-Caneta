# ============================================================
# ASSISTENTE DE CANETA — variáveis de ambiente
# Copie para .env e gere chaves com: npm run gen:keys
# NUNCA commitar o arquivo .env
# ============================================================

NODE_ENV=development
PORT=3000

# PostgreSQL (docker-compose local usa porta 5433)
DATABASE_URL=postgresql://app:dev_local_only_change_in_prod@localhost:5433/assistente_caneta
# Em produção (Railway) use a DATABASE_URL fornecida + PGSSL=true
PGSSL=false

# JWT — gere com npm run gen:keys
JWT_SECRET=troque_me
JWT_EXPIRES=15m
REFRESH_EXPIRES_DAYS=30

# Criptografia de dados de saúde (AES-256-GCM) — 32 bytes em hex (64 chars)
# gere com npm run gen:keys
DATA_ENCRYPTION_KEY=troque_me

# CORS — origem do app Flutter web / dev
CORS_ORIGIN=http://localhost:8080

# Rate limiting
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# Sentry (opcional — vazio desativa)
SENTRY_DSN=

# Resend (e-mail transacional — opcional no MVP local)
RESEND_API_KEY=
EMAIL_FROM=Assistente de Caneta <no-reply@seudominio.com.br>
